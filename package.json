{
  "name": "zen-font-scale",
  "displayName": "Zen Font Scale",
  "description": "Automatically scales editor font size when entering Zen Mode",
  "publisher": "gligoran",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gligoran/zen-font-scale"
  },
  "homepage": "https://github.com/gligoran/zen-font-scale#readme",
  "bugs": {
    "url": "https://github.com/gligoran/zen-font-scale/issues"
  },
  "keywords": [
    "zen mode",
    "font size",
    "font scale",
    "focus",
    "distraction free"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "zenFontScale.toggle",
        "title": "Zen Font Scale: Toggle Zen Mode with Font Scaling"
      }
    ],
    "keybindings": [
      {
        "command": "zenFontScale.toggle",
        "key": "ctrl+k z",
        "mac": "cmd+k z",
        "when": "!inZenMode"
      },
      {
        "command": "zenFontScale.toggle",
        "key": "ctrl+k z",
        "mac": "cmd+k z",
        "when": "inZenMode"
      }
    ],
    "configuration": {
      "title": "Zen Font Scale",
      "properties": {
        "zenFontScale.scaleFactor": {
          "type": "number",
          "default": 1.5,
          "minimum": 1.0,
          "maximum": 3.0,
          "description": "Font size multiplier when entering Zen Mode"
        }
      }
    }
  },
  "scripts": {
    "compile": "bun build src/extension.ts --outdir=dist --external vscode --format=cjs --target=node",
    "watch": "bun build src/extension.ts --outdir=dist --external vscode --format=cjs --target=node --watch",
    "package": "bun build src/extension.ts --outdir=dist --external vscode --format=cjs --target=node --minify",
    "vsce:package": "vsce package",
    "vsce:publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0"
  }
}
