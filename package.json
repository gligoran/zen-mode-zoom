{
  "name": "zen-font-scale",
  "displayName": "Zen Font Scale",
  "description": "Automatically scales editor font size when entering Zen Mode",
  "publisher": "gligoran",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "zenFontScale.toggle",
        "title": "Zen Font Scale: Toggle Zen Mode with Font Scaling"
      }
    ],
    "keybindings": [
      {
        "command": "zenFontScale.toggle",
        "key": "ctrl+k z",
        "mac": "cmd+k z",
        "when": "!inZenMode"
      },
      {
        "command": "zenFontScale.toggle",
        "key": "ctrl+k z",
        "mac": "cmd+k z",
        "when": "inZenMode"
      }
    ],
    "configuration": {
      "title": "Zen Font Scale",
      "properties": {
        "zenFontScale.scaleFactor": {
          "type": "number",
          "default": 1.5,
          "minimum": 1.0,
          "maximum": 3.0,
          "description": "Font size multiplier when entering Zen Mode"
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run compile -- --watch",
    "package": "npm run compile -- --minify"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
