{
  "name": "zen-mode-zoom",
  "displayName": "Zen Mode Zoom",
  "description": "Automatically zooms in the UI when entering Zen Mode",
  "publisher": "gligoran",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gligoran/zen-mode-zoom"
  },
  "homepage": "https://github.com/gligoran/zen-mode-zoom#readme",
  "bugs": {
    "url": "https://github.com/gligoran/zen-mode-zoom/issues"
  },
  "keywords": [
    "zen mode",
    "zoom",
    "ui scale",
    "focus",
    "distraction free"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "zenModeZoom.toggle",
        "title": "Zen Mode Zoom: Toggle Zen Mode with Zoom"
      }
    ],
    "keybindings": [
      {
        "command": "zenModeZoom.toggle",
        "key": "ctrl+k z",
        "mac": "cmd+k z",
        "when": "!inZenMode"
      },
      {
        "command": "zenModeZoom.toggle",
        "key": "ctrl+k z",
        "mac": "cmd+k z",
        "when": "inZenMode"
      }
    ],
    "configuration": {
      "title": "Zen Mode Zoom",
      "properties": {
        "zenModeZoom.zoomIncrement": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 5,
          "description": "Amount to add to the current window.zoomLevel when entering Zen Mode. The original zoom level is restored on exit."
        }
      }
    }
  },
  "scripts": {
    "compile": "bun build src/extension.ts --outdir=dist --external vscode --format=cjs --target=node",
    "watch": "bun build src/extension.ts --outdir=dist --external vscode --format=cjs --target=node --watch",
    "package": "bun build src/extension.ts --outdir=dist --external vscode --format=cjs --target=node --minify",
    "vsce:package": "vsce package",
    "vsce:publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0"
  }
}
